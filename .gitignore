*.db
*.sqlite
!**/schema*.sql
!**/*.schema

# Bun lock (regenerable)
bun.lock

# Auto-generated backups
MEMORY.md.bak
MEMORY.md.pre-test
*.bak

# Media artifacts
video-frame.jpg

# Sensitive data
proxies.txt

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Python
*.egg-info/
dist/
build/

# Docker
.lighter-copilot-data/

# Session transcripts (runtime, not source)
*.jsonl

