# Dependencies
node_modules/
venv/
__pycache__/
*.pyc
*.pyo

# Environment / secrets
.env
*.env
.env.*

# Runtime config (may contain API keys)
lighter-copilot/config.yml
lighter-bot/config.yml

# Logs
*.log
bot.log
scanner.log
logs/

# Runtime state
state/
data/

