[flake8]
max-line-length = 130
exclude =
    venv,
    __pycache__,
    .git,
    .pytest_cache
# Ignore cosmetic/style issues in existing codebase
# E501: line too long (handled by max-line-length above)
# E402: module level import not at top (needed for sys.path setup)
# E302/E303/E305: blank line conventions
# E127/E128: continuation line indentation
# E261: inline comment spacing
# W293: blank line contains whitespace
# F541: f-string without placeholders (harmless in logging)
ignore = E501, E402, E302, E303, E305, E127, E128, E226, E241, E261, W293, W504, F541, F841
per-file-ignores =
    tests/*:E402
