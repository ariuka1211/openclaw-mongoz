{
    "max_open_trades": 3,
    "stake_currency": "USDC",
    "stake_amount": 20,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 1000,
    "cancel_open_orders_on_exit": false,
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "lighter",
        "ccxt_config": {
            "enableRateLimit": true,
            "options": {
                "defaultType": "swap",
                "chainId": 304,
                "wasmExecPath": "/freqtrade/lighter-wasm/wasm_exec.js",
                "libraryPath": "/freqtrade/lighter-wasm/lighter.wasm"
            }
        },
        "pair_whitelist": [
            "BTC/USDC:USDC",
            "ETH/USDC:USDC",
            "SOL/USDC:USDC"
        ],
        "pair_blacklist": [
            "*/BNB",
            "*/BUSD"
        ]
    },
    "pairlists": [
        {"method": "StaticPairList"}
    ],
    "timeframe": "5m",
    "protections": [
        {
            "method": "StoplossGuard",
            "lookback_period_candles": 60,
            "trade_limit": 4,
            "stop_duration_candles": 20,
            "only_per_pair": false
        },
        {
            "method": "MaxDrawdown",
            "lookback_period_candles": 200,
            "trade_limit": 20,
            "stop_duration_candles": 10,
            "max_allowed_drawdown": 0.2
        },
        {
            "method": "LowProfitPairs",
            "lookback_period_candles": 400,
            "trade_limit": 2,
            "stop_duration_candles": 60,
            "required_profit": 0.02
        }
    ],
    "internals": {
        "process_throttle_secs": 5
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "somethingrandomsomethingrandom123456789012345",
        "username": "freqtrader",
        "password": "SuperSecret1234!",
        "ws_token": "secret_ws_token123"
    }
}